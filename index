const likertLabels = ["غائبة","محدودة","جزئية","جيدة","كاملة"];

// ============================================================
// STATE
// ============================================================
let currentStep = 0;
const TOTAL_STEPS = 8;
let answers = {}; // key: "d{dim}q{q}" => value 1-5

// ============================================================
// BUILD DIMENSION PAGES
// ============================================================
function buildDimPage(dimIndex) {
  const dim = dimensions[dimIndex];
  const pageEl = document.getElementById('page-' + (dimIndex + 2));

  let html = `
    <div class="dim-header">
      <div class="dim-num">البُعد ${dim.id} من 5 &nbsp;|&nbsp; ${dim.nameEn}</div>
      <h2>${dim.nameAr}</h2>
      <p>${dim.descAr}</p>
    </div>
    <div id="dimWarning-${dimIndex}" class="warning-box">يرجى الإجابة على جميع الأسئلة في هذا البُعد قبل المتابعة.</div>
  `;

  dim.questions.forEach(function(qText, qIndex) {
    const key = 'd' + dimIndex + 'q' + qIndex;
    html += `
      <div class="question-block" id="qblock-${key}">
        <div class="question-text">
          <span class="question-num">${qIndex + 1}</span>
          ${qText}
        </div>
        <div class="likert-scale">
    `;
    for (let v = 1; v <= 5; v++) {
      html += `
          <div class="likert-option">
            <input type="radio" name="${key}" id="${key}-${v}" value="${v}" onchange="recordAnswer('${key}', ${v})">
            <label for="${key}-${v}">
              <span class="num">${v}</span>
              <span class="lbl">${likertLabels[v-1]}</span>
            </label>
          </div>
      `;
    }
    html += `
        </div>
        <div class="likert-scale-labels">
          <span>1 = غير موجودة اطلاقاً</span>
          <span>5 = مطبقة بالكامل</span>
        </div>
      </div>
    `;
  });

  let isLast = (dimIndex === 4);
  html += `
    <div class="nav-buttons">
      <button class="btn btn-secondary" onclick="prevStep()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        السابق
      </button>
      <button class="btn ${isLast ? 'btn-success' : 'btn-primary'}" onclick="validateDimAndNext(${dimIndex})">
        ${isLast ? 'عرض النتائج' : 'التالي: البُعد ' + (dim.id + 1)}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
    </div>
  `;

  pageEl.innerHTML = html;
}

// ============================================================
// ANSWER RECORDING
// ============================================================
function recordAnswer(key, value) {
  answers[key] = value;
  const block = document.getElementById('qblock-' + key);
  if (block) {
    block.classList.add('answered');
  }
}

// ============================================================
// NAVIGATION
// ============================================================
function goToStep(step) {
  document.getElementById('page-' + currentStep).classList.remove('active');
  document.getElementById('page-' + step).classList.add('active');
  currentStep = step;
  updateProgress();
  updateStepNav();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function nextStep() {
  if (currentStep < TOTAL_STEPS - 1) {
    goToStep(currentStep + 1);
  }
}

function prevStep() {
  if (currentStep > 0) {
    goToStep(currentStep - 1);
  }
}

function updateProgress() {
  var pct = Math.round((currentStep / (TOTAL_STEPS - 1)) * 100);
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('stepLabel').textContent = 'الخطوة ' + (currentStep + 1) + ' من ' + TOTAL_STEPS;
  document.getElementById('pctLabel').textContent = pct + '%';
}

function updateStepNav() {
  var btns = document.querySelectorAll('.step-btn');
  btns.forEach(function(btn, i) {
    btn.classList.remove('active', 'done');
    if (i === currentStep) btn.classList.add('active');
    else if (i < currentStep) btn.classList.add('done');
  });
}

// ============================================================
// VALIDATION
// ============================================================
function validateOrgAndNext() {
  var sector = document.getElementById('orgSector').value;
  var size = document.getElementById('orgSize').value;
  var loc = document.getElementById('orgLocation').value;
  var ai = document.getElementById('aiUsage').value;
  var warn = document.getElementById('orgWarning');
  if (!sector || !size || !loc || !ai) {
    warn.classList.add('show');
    return;
  }
  warn.classList.remove('show');
  nextStep();
}

function validateDimAndNext(dimIndex) {
  var dim = dimensions[dimIndex];
  var allAnswered = true;
  dim.questions.forEach(function(q, qi) {
    var key = 'd' + dimIndex + 'q' + qi;
    if (!answers[key]) {
      allAnswered = false;
      var block = document.getElementById('qblock-' + key);
      if (block) {
        block.style.border = '2px solid #e74c3c';
        block.style.background = '#fff5f5';
        setTimeout(function() {
          block.style.border = '';
          block.style.background = '';
        }, 2500);
      }
    }
  });
  var warn = document.getElementById('dimWarning-' + dimIndex);
  if (!allAnswered) {
    if (warn) warn.classList.add('show');
    return;
  }
  if (warn) warn.classList.remove('show');
  if (dimIndex === 4) {
    buildResults();
    goToStep(7);
  } else {
    nextStep();
  }
}

// ============================================================
// RESULTS
// ============================================================
function getDimScore(dimIndex) {
  var total = 0;
  dimensions[dimIndex].questions.forEach(function(q, qi) {
    var key = 'd' + dimIndex + 'q' + qi;
    total += answers[key] ? parseInt(answers[key]) : 0;
  });
  return total;
}

function buildResults() {
  var dimScores = [];
  var grandTotal = 0;
  dimensions.forEach(function(dim, i) {
    var s = getDimScore(i);
    dimScores.push(s);
    grandTotal += s;
  });

  var maxPerDim = 20;
  var maxTotal = 100;
  var pct = Math.round((grandTotal / maxTotal) * 100);

  // Score display
  document.getElementById('totalScore').textContent = pct;

  // Maturity level
  var level, levelClass, title, desc;
  if (pct <= 35) {
    level = "Emerging (ناشئ)";
    levelClass = "maturity-emerging";
    title = "مستوى ناشئ: الجاهزية في مراحلها الأولى";
    desc = "تفتقر المنظمة إلى معظم عناصر حوكمة الذكاء الاصطناعي. التدخل العاجل ضروري لبناء الأسس اللازمة وتفادي المخاطر المرتبطة باعتماد الذكاء الاصطناعي دون إطار حوكمي واضح.";
  } else if (pct <= 55) {
    level = "Developing (في طور التطوير)";
    levelClass = "maturity-developing";
    title = "مستوى في طور التطوير: أسس جيدة تحتاج تعزيزاً";
    desc = "توجد بعض العناصر الجيدة لكنها تبقى جزئية وغير مكتملة. هذه المرحلة تستدعي تسريع بناء السياسات وتعزيز الكفاءات التقنية ومأسسة آليات المساءلة.";
  } else if (pct <= 75) {
    level = "Established (راسخ)";
    levelClass = "maturity-established";
    title = "مستوى راسخ: حوكمة ذكاء اصطناعي وظيفية";
    desc = "تمتلك المنظمة إطاراً حوكمياً وظيفياً بممارسات موثقة وعمليات مؤسسية. التحسين مستمر يستهدف سد الثغرات المتبقية في الأبعاد الأضعف والارتقاء نحو التميز.";
  } else {
    level = "Advanced (متقدم)";
    levelClass = "maturity-advanced";
    title = "مستوى متقدم: نموذج رائد في حوكمة الذكاء الاصطناعي";
    desc = "تُعدّ المنظمة نموذجاً يُحتذى به على مستوى القطاع. الجهود الآن تتمحور حول الابتكار المستمر في الحوكمة ومشاركة الخبرات مع المنظمات الأخرى.";
  }

  var badge = document.getElementById('maturityBadge');
  badge.textContent = level;
  badge.className = 'maturity-badge ' + levelClass;
  document.getElementById('maturityTitle').textContent = title;
  document.getElementById('maturityDesc').textContent = desc;

  // Dim scores grid
  var colors = ['#e74c3c','#e67e22','#f1c40f','#2ecc71','#3498db'];
  var grid = document.getElementById('dimScoresGrid');
  grid.innerHTML = '';
  dimensions.forEach(function(dim, i) {
    var s = dimScores[i];
    var pctDim = Math.round((s / maxPerDim) * 100);
    var col = pctDim >= 75 ? '#27ae60' : pctDim >= 50 ? '#f39c12' : '#e74c3c';
    grid.innerHTML += '<div class="dim-score-card">' +
      '<div class="dim-name">' + dim.nameAr + '<br><small style="font-weight:400;color:var(--muted);">' + dim.nameEn + '</small></div>' +
      '<div class="score-bar-track"><div class="score-bar-fill" style="width:' + pctDim + '%;background:' + col + ';"></div></div>' +
      '<div class="dim-score-meta"><span class="val">' + s + ' / ' + maxPerDim + '</span><span>' + pctDim + '%</span></div>' +
      '</div>';
  });

  // Comparison table
  var tbody = document.getElementById('compTableBody');
  tbody.innerHTML = '';
  dimensions.forEach(function(dim, i) {
    var s = dimScores[i];
    var avg = dim.studyAvg;
    var gap = (s - avg).toFixed(1);
    var gapStr = gap > 0 ? '+' + gap : '' + gap;
    var gapColor = gap > 0 ? 'color:var(--success)' : gap < 0 ? 'color:var(--danger)' : '';
    tbody.innerHTML += '<tr>' +
      '<td>' + dim.nameAr + '</td>' +
      '<td><strong>' + s.toFixed(1) + '</strong></td>' +
      '<td>' + avg + '</td>' +
      '<td style="' + gapColor + ';font-weight:700;">' + gapStr + '</td>' +
      '</tr>';
  });
  // Total row
  var studyTotal = dimensions.reduce(function(a, d) { return a + d.studyAvg; }, 0);
  var totalGap = (grandTotal - studyTotal).toFixed(1);
  var totalGapStr = totalGap > 0 ? '+' + totalGap : '' + totalGap;
  tbody.innerHTML += '<tr class="highlight">' +
    '<td>المجموع الكلي</td>' +
    '<td><strong>' + grandTotal + '</strong></td>' +
    '<td>' + studyTotal.toFixed(1) + '</td>' +
    '<td style="font-weight:700;">' + totalGapStr + '</td>' +
    '</tr>';

  // Recommendations
  var sorted = dimScores.map(function(s, i) { return { i: i, s: s, pct: Math.round((s/maxPerDim)*100) }; })
    .sort(function(a, b) { return a.pct - b.pct; });

  var recDefs = [
    [
      "البُعد الأول (الاستراتيجية والقيادة): ابدأ بصياغة ورقة موقف تنظيمية حول الذكاء الاصطناعي، وتعيين مسؤول تنفيذي مكلف رسمياً بملف الحوكمة، ووضع خارطة طريق بأهداف قابلة للقياس على المدى القصير والمتوسط.",
      "البُعد الثاني (الإطار التنظيمي): أعطِ الأولوية لوضع سياسة استخدام مقبول للذكاء الاصطناعي وآليات الامتثال، بالاستناد إلى معايير ISO/IEC 42001 وإرشادات اليونسكو لأخلاقيات الذكاء الاصطناعي.",
      "البُعد الثالث (الجاهزية التقنية): استثمر في تدريب الكوادر التقنية وتحديث البنية التحتية للبيانات، مع اعتماد منهجيات موثقة لتطوير النماذج وإدارة دورة حياتها.",
      "البُعد الرابع (الشفافية والمساءلة): أنشئ سجلاً داخلياً لأنظمة الذكاء الاصطناعي المستخدمة، وحدد قنوات تواصل واضحة لتلقي الملاحظات، وطوّر إجراءات للتدقيق الدوري.",
      "البُعد الخامس (الأخلاقيات والشمولية): طوّر ميثاق أخلاقيات خاص بالمنظمة، وادرج تقييمات التحيز ضمن دورة تطوير الأنظمة، وخصص ميزانية للتدريب على الذكاء الاصطناعي المسؤول."
    ]
  ];

  var allRecs = [
    "البُعد الأول (الاستراتيجية والقيادة): ابدأ بصياغة ورقة موقف تنظيمية حول الذكاء الاصطناعي وتعيين مسؤول تنفيذي مكلف رسمياً بملف الحوكمة مع وضع خارطة طريق بأهداف قابلة للقياس.",
    "البُعد الثاني (الإطار التنظيمي): أعطِ الأولوية لوضع سياسة استخدام مقبول للذكاء الاصطناعي وآليات الامتثال بالاستناد إلى معايير ISO/IEC 42001 وإرشادات اليونسكو.",
    "البُعد الثالث (الجاهزية التقنية): استثمر في تدريب الكوادر التقنية وتحديث البنية التحتية للبيانات مع اعتماد منهجيات موثقة لتطوير النماذج.",
    "البُعد الرابع (الشفافية والمساءلة): أنشئ سجلاً داخلياً لأنظمة الذكاء الاصطناعي وحدد قنوات تواصل واضحة لتلقي الملاحظات وطوّر إجراءات للتدقيق الدوري.",
    "البُعد الخامس (الأخلاقيات والشمولية): طوّر ميثاق أخلاقيات خاص بالمنظمة وادرج تقييمات التحيز ضمن دورة تطوير الأنظمة وخصص ميزانية للتدريب على الذكاء الاصطناعي المسؤول."
  ];

  var recs = document.getElementById('recsContainer');
  recs.innerHTML = '';
  sorted.slice(0, 3).forEach(function(item, rank) {
    var cls = rank === 0 ? 'rec-high' : rank === 1 ? 'rec-med' : 'rec-low';
    var priority = rank === 0 ? 'أولوية عالية' : rank === 1 ? 'أولوية متوسطة' : 'أولوية منخفضة';
    recs.innerHTML += '<div class="rec-card ' + cls + '">' +
      '<div class="priority">' + priority + '</div>' +
      '<div class="rec-text">' + allRecs[item.i] + '</div>' +
      '</div>';
  });
}

// ============================================================
// RESET
// ============================================================
function resetAssessment() {
  answers = {};
  // Reset radio buttons
  document.querySelectorAll('input[type="radio"]').forEach(function(r) { r.checked = false; });
  document.querySelectorAll('.question-block').forEach(function(b) { b.classList.remove('answered'); });
  document.getElementById('orgSector').value = '';
  document.getElementById('orgSize').value = '';
  document.getElementById('orgLocation').value = '';
  document.getElementById('aiUsage').value = '';
  goToStep(0);
}

// ============================================================
// INIT
// ============================================================
(function init() {
  dimensions.forEach(function(dim, i) {
    buildDimPage(i);
  });
  updateProgress();
  updateStepNav();
})();
</script>
